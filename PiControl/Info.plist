<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Cache l'icône du Dock — app menu bar uniquement -->
    <key>LSUIElement</key>
    <true/>
    <key>CFBundleExecutable</key>
    <string>Pironman5 Controller</string>
    <key>CFBundleName</key>
    <string>PiControl</string>
    <key>CFBundleDisplayName</key>
    <string>PiControl</string>
    <key>CFBundleIdentifier</key>
    <string>com.local.pironman5controller</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Autorise les requêtes HTTP vers l'API locale du Pi (port 34001) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
